#!/bin/bash
set -euo pipefail
CMD=${1:-status}
FANCTL_DIR="/usr/local/lib/fanctl-systemd"
[ -d "$FANCTL_DIR" ] || FANCTL_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"

die() { echo "fanctl: $*" >&2; exit 1; }
usage() {
    cat <<EOF
Usage: $0 <command>

Commands:
  <0-100>        Set fan speed to N% (all channels)
  max            Set fans to 100%
  half           Set fans to 50%
  auto           Restore automatic BMC fan control
  status         Show current fan RPM & temp
  watch          Watchdog: hand to BMC auto on critical CPU temp
  night          Enable systemd night mode (23:00 → 10%, 07:00 → auto)
  day            Disable systemd night mode

Examples:
  $0 max         # 100%
  $0 half        # 50%
  $0 auto        # BMC back in control
  $0 10          # quiet mode
  $0 watch       # safety net: ramp on heat, revert on critical
EOF
    exit 1
}

auto_cmd() {
    ipmitool raw 0x3a 0x01 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 >/dev/null
    echo "→ BMC auto fan control restored"
}
pct_cmd() {
    [ "$1" -le 100 ] || die "0–100 only"
    local h=$(printf '0x%02x' "$1")
    ipmitool raw 0x3a 0x01 "$h" "$h" "$h" "$h" "$h" "$h" "$h" "$h" >/dev/null
    echo "→ Fans set to ${1}%"
}

case "$CMD" in
    auto)   auto_cmd ;;
    max)    pct_cmd 100 ;;
    half)   pct_cmd 50 ;;
    status) echo "=== Fans ==="; ipmitool sdr list 2>/dev/null | grep -i fan
            echo; echo "=== Temperatures ==="; ipmitool sdr type temperature 2>/dev/null ;;
    watch)  interval=${WATCH_INTERVAL:-10}
            crit=${WATCH_CRIT:-85}
            echo "fanctl watch: polling CPU every ${interval}s, ≥${crit}°C→auto. Ctrl-C to stop."
            while :; do
                temp=$(ipmitool sdr type temperature 2>/dev/null | \
                       grep -i cpu | head -1 | \
                       sed 's/.*| *\([0-9]\{1,3\}\) degrees.*/\1/')
                if [ -z "$temp" ]; then
                    echo "fanctl watch: temp read failed — handing to auto for safety"
                    auto_cmd
                    exit 1
                fi
                if [ "$temp" -ge "$crit" ]; then
                    echo "fanctl watch: ${temp}°C ≥ ${crit}°C critical — handing to BMC auto"
                    auto_cmd
                    exit 1
                fi
                sleep "$interval"
            done ;;
    night)  [[ -d "$FANCTL_DIR/systemd" ]] || die "systemd units not found — run install.sh first"
            cp "$FANCTL_DIR"/systemd/*.service "$FANCTL_DIR"/systemd/*.timer /etc/systemd/system/
            systemctl daemon-reload
            systemctl enable --now quiet-night.timer loud-day.timer
            systemctl start quiet-night
            echo "→ Night mode on (23:00 → 10%, 07:00 → auto)" ;;
    day)    systemctl disable --now quiet-night.timer loud-day.timer 2>/dev/null || true
            systemctl stop quiet-night loud-day 2>/dev/null || true
            auto_cmd ;;
    -h|--help) usage ;;
    *)      if [[ "$CMD" =~ ^[0-9]+$ ]]; then pct_cmd "$CMD"; else usage; fi ;;
esac